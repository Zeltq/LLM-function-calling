# Hugging Face Token (обязательно)
# Получите токен: https://huggingface.co/settings/tokens
HF_TOKEN=your_token_here

# Идентификатор модели на Hugging Face (по умолчанию: Qwen/Qwen2.5-3B-Instruct)
# MODEL_ID=Qwen/Qwen2.5-3B-Instruct

# Максимум сообщений каждой роли в контексте модели (по умолчанию: 3)
# MAX_CONTEXT_MESSAGES=3

# Максимум токенов при генерации ответа (по умолчанию: 256)
# MAX_NEW_TOKENS=256

# Максимальный размер истории диалога в интерактивном режиме (по умолчанию: 1000)
# MAX_HISTORY_SIZE=1000
